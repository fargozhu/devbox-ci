{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.1/.schema/devbox.schema.json",
  "packages": {
    "pack": {
      "version": "latest",
      "platforms": [
        "x86_64-linux",
        "aarch64-darwin"
      ]
    },
    "colima": {
      "version": "latest",
      "platforms": [
        "x86_64-linux",
        "aarch64-darwin"
      ]
    },
    "go": {
      "version": "1.25.0",
      "platforms": [
        "x86_64-linux",
        "aarch64-darwin"
      ]
    },
    "cdxgen": {
      "version": "latest",
      "platforms": [
        "x86_64-linux",
        "aarch64-darwin"
      ]
    }
  },
  "env": {
    "GOPATH": "$HOME/go/",
    "PATH":   "$PATH:$HOME/go/bin"
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "check": [
        "echo Checking..."
      ],
      "test": [
        "echo Testing..."
      ],
      "run-local": [
        "echo Running...",
        "go run main.go"
      ],
      "build-publish": [
        "echo Building...",        
        "docker build -t ttl.sh/my-app:2h .",
        "docker push ttl.sh/my-app:2h"
      ],
      "buildpack": [
        "echo Buildpacking...",        
        "pack build ttl.sh/fargozhu-app:1h --buildpack paketo-buildpacks/go --builder paketobuildpacks/builder-jammy-base",
      ],
      "deploy": [
        "echo Deploy..."
      ],
      "clean": [
        "echo Cleaning..."
      ],
      "sbom": [
        "echo Generating SBOM...",
        "cdxgen -t go -o bom.json -p"        
      ],
      "sbom-buildpack": [
        "pack sbom download ttl.sh/fargozhu-app:1h --output-dir /tmp/sbom",
        "cat /tmp/sbom"
      ]
    }
  }
}
