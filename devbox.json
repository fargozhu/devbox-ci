{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.1/.schema/devbox.schema.json",
  "packages": [
    "go@1.25.6",
    "pack@latest",
    "colima@latest"
  ],
  "env": {
    "GOPATH": "$HOME/go/",
    "PATH":   "$PATH:$HOME/go/bin"
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "check": [
        "echo Checking..."
      ],
      "test": [
        "echo Testing..."
      ],
      "run": [
        "echo Running...",
        "go run main.go"
      ],
      "build": [
        "echo Building...",
        "pack build hello --buildpack paketo-buildpacks/go --builder paketobuildpacks/builder-jammy-base"
      ]
    }
  }
}
